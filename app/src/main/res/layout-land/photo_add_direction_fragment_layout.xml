    <LinearLayout
       android:orientation="vertical"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:visibility="visible">

      <TextView
          android:id="@+id/textView"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >
      </TextView>

      <TextView
          android:id="@+id/textView2"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >

	  </TextView>
	  <TextView
          android:id="@+id/textView3"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >
	  </TextView>
      <TextView
          android:id="@+id/textView4"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >

	  </TextView>

      </LinearLayout>

      <LinearLayout
          android:id="@+id/plan_sidesubmenu_buttons"
          android:layout_width="wrap_content"
          android:layout_height="fill_parent"
          android:layout_gravity="bottom|right"
          android:orientation="horizontal"
          android:visibility="visible" >

		  <LinearLayout
			  android:id="@+id/plan_submenu_buttons_expanded"
			  android:layout_width="wrap_content"
			  android:layout_height="81dp"
			  android:layout_gravity="bottom|right"
			  android:orientation="horizontal"
			  android:visibility="gone">

			  <ImageView
				  android:id="@+id/button_delete_location"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_selector_039"
				  android:visibility="visible" />

			  <ImageView
				  android:id="@+id/button_arrow_rotate"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_selector_039"
				  android:visibility="visible" />

			  <ImageView
				  android:id="@+id/button_plan"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_overview_028"
				  android:text="norotate"
				  android:visibility="visible" />
		  </LinearLayout>


      <LinearLayout
          android:id="@+id/plan_submenu_buttons"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom|right"
          android:orientation="vertical"
          android:visibility="gone" >


		   <ImageView
		       android:id="@+id/button_cancel_and_back"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
			   android:src="@drawable/pd_plan_selector_039"
		       android:visibility="gone"
		       android:text="config" />

		   <ImageView
		       android:id="@+id/button_save_and_back"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
		       android:src="@drawable/pd_plan_save_085"
		       android:visibility="gone"
		       android:text="Plan" />

		   <ImageView
		       android:id="@+id/button_config"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
			   android:src="@drawable/pd_plan_selector_039"
		       android:visibility="visible"/>

	    </LinearLayout>
    </LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:visibility="gone"
		>

		<TextView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:text="Test"
			android:layout_margin="5dp"
			android:textColor="#ff0000"
			android:textSize="20dp"
			android:id="@+id/debugTextView"
		/>

	</LinearLayout>
	<ImageView
		android:id="@+id/iv_temp"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:focusable="false"
		android:visibility="gone"

		android:src="@drawable/floor_1"
		android:focusableInTouchMode="false" />

	<RelativeLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		>

		<ImageView
			android:id="@+id/iv_back_arrow"
			android:layout_width="@dimen/plan_direction_screen_view_height"
			android:layout_height="@dimen/plan_direction_screen_view_height"
			android:gravity="center"
			android:padding="3dp"
			android:layout_marginLeft="@dimen/size10"
			android:layout_marginTop="@dimen/card_corner_radius_5dp"
			android:src="@drawable/filled_back"
			/>


		<LinearLayout
			android:id="@+id/ll_four_buttons"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:weightSum="4"
			android:background="@color/gray_lighter_light_hover"
			android:layout_toStartOf="@+id/ll_icons"
			android:padding="5dp"
			>
			<LinearLayout
				android:layout_weight="1"
				android:orientation="vertical"
				android:gravity="center"
				android:layout_width="wrap_content"
				android:layout_height="0dp">

				<ImageView
					android:id="@+id/iv_satellite"
					android:layout_width="45dp"
					android:layout_height="45dp"
					android:layout_marginTop="3dp"

					android:contentDescription="Plan"
					android:layout_marginRight="5dp"
					android:src="@drawable/satellite_icon"
					android:textColor="@color/white_text_color" />
				<TextView
					android:gravity="center"
					android:layout_gravity="center"
					android:paddingLeft="6dp"
					android:paddingRight="6dp"
					android:textSize="12sp"
					android:visibility="invisible"
					android:id="@+id/tv_accuracy"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text=""
					/>
			</LinearLayout>


			<ImageView
				android:id="@+id/iv_compass"
				android:layout_width="45dp"
				android:layout_height="0dp"
				android:layout_marginTop="3dp"
				android:layout_weight="1"
				android:contentDescription="Tag"
				android:src="@drawable/compas_icon"
				android:textColor="@color/white_text_color" />

			<ImageView
				android:id="@+id/iv_plan"
				android:layout_width="45dp"
				android:layout_height="0dp"
				android:layout_marginTop="3dp"
				android:layout_weight="1"
				android:contentDescription="record"
				android:src="@drawable/plans_black"
				android:textColor="@color/white_text_color" />

			<ImageView
				android:id="@+id/iv_delete"
				android:layout_width="45dp"
				android:layout_height="0dp"
				android:layout_marginTop="3dp"
				android:layout_weight="1"
				android:contentDescription="brush"
				android:src="@drawable/delete_icon_direction_screen"
				android:textColor="@color/white_text_color" />
		</LinearLayout>

		<LinearLayout
			android:id="@+id/ll_icons"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:background="@color/white"
			android:clickable="true"
			android:gravity="center"
			android:orientation="vertical"
			android:padding="5dp"
			android:visibility="visible"
			android:weightSum="2"
			android:layout_alignParentRight="true">




			<LinearLayout
				android:layout_width="45dp"
				android:layout_height="0dp"
				android:layout_marginTop="3dp"
				android:layout_weight="1"
				android:gravity="center"
				android:padding="3dp"
				android:id="@+id/ll_next"

				>

				<ImageView
					android:id="@+id/tv_save"
					android:layout_width="40dp"
					android:layout_height="40dp"
					android:gravity="center"
					android:src="@drawable/ic_tick_fill"


					/>
			</LinearLayout>
			<LinearLayout
				android:layout_width="45dp"
				android:id="@+id/ll_previous"
				android:layout_height="0dp"
				android:layout_marginTop="3dp"
				android:layout_weight="1"
				android:padding="3dp"
				android:gravity="center">

				<ImageView
					android:id="@+id/tv_cancel"
					android:layout_width="40dp"
					android:layout_height="40dp"
					android:gravity="center"
					android:src="@drawable/ic_cross_fill"
					/>
			</LinearLayout>

		</LinearLayout>

