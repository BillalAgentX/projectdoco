<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/show_photo_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.add_direction.ProjectDocuMainActivity">


    <com.projectdocupro.mobile.fragments.add_direction.EnhancedWebView
        android:id="@+id/webview_plan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:longClickable="true" />

    <ImageButton
        android:id="@+id/crosshair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:clickable="true"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/crosshair" />

    <ImageView
        android:id="@+id/touch_helper_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/color_transparent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <ImageView
        android:id="@+id/arrow_touch_helper_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/arrow_transparent"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/button_capture_photo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="top|right"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:scaleType="fitCenter"
        android:src="@drawable/pd_button_camera_008"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/rotation_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/rotation_arrow_top"
        android:visibility="visible" />

    <ImageButton
        android:id="@+id/rotation_arrow_helper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="35dp"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/rotation_arrow_helper"
        android:visibility="invisible" />

    <!--
          <LinearLayout
           android:id="@+id/preview_function_buttons"
           android:orientation="vertical"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:visibility="visible">

                <ImageView
                    android:id="@+id/menu_bar_plan_button_gps"
                    android:layout_width="57dp"
                    android:layout_height="57dp"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/pd_plan_gps_044" />

                <ImageView
                    android:id="@+id/menu_bar_plan_button_compass"
                    android:layout_width="57dp"
                    android:layout_height="57dp"
                    android:onClick="zoomOut"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/pd_plan_compass_043" />

           </LinearLayout>
    -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000"></TextView>

        <TextView
            android:id="@+id/textView2"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000">

        </TextView>

        <TextView
            android:id="@+id/textView3"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000"></TextView>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000">

        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/plan_sidesubmenu_buttons"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_gravity="bottom|right"
        android:orientation="horizontal"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/plan_submenu_buttons_expanded"
            android:layout_width="wrap_content"
            android:layout_height="81dp"
            android:layout_gravity="bottom|right"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/button_delete_location"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/button_arrow_rotate"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/button_plan"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_overview_028"
                android:text="norotate"
                android:visibility="visible" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/plan_submenu_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|right"
            android:orientation="vertical"
            android:visibility="gone">


            <ImageView
                android:id="@+id/button_cancel_and_back"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:text="config"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/button_save_and_back"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_save_085"
                android:text="Plan"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/button_config"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/debugTextView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:text="Test"
            android:textColor="#ff0000"
            android:textSize="20dp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/iv_temp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/yellow"
        android:focusable="false"

        android:focusableInTouchMode="false"
        android:src="@drawable/floor_1"
        android:visibility="gone" />


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/iv_back_arrow"
            android:layout_width="@dimen/plan_direction_screen_view_height"
            android:layout_height="@dimen/plan_direction_screen_view_height"
            android:layout_marginLeft="@dimen/size10"
            android:layout_marginTop="@dimen/card_corner_radius_5dp"
            android:gravity="center"
            android:padding="3dp"
            android:src="@drawable/filled_back"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llRemaining"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/containerButtons"
            android:orientation="vertical"
            android:visibility="visible"></LinearLayout>

        <LinearLayout
            android:id="@+id/containerButtons"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/ll_icons"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@color/gray_lighter_light_hover"
                android:clickable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp"
                android:visibility="visible">


                <ImageView
                    android:id="@+id/iv_satellite"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginRight="5dp"
                    android:layout_weight="1"
                    android:contentDescription="Plan"
                    android:src="@drawable/satellite_icon"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/iv_compass"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="3dp"
                    android:layout_weight="1"
                    android:contentDescription="Tag"
                    android:src="@drawable/compas_icon"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/iv_plan"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="3dp"
                    android:layout_weight="1"
                    android:contentDescription="record"
                    android:src="@drawable/plans_black"
                    android:textColor="@color/white_text_color"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/iv_delete"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="1"
                    android:contentDescription="brush"
                    android:src="@drawable/crop"
                    android:textColor="@color/white_text_color" />


            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_bottom_tabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@color/gray_lighter_light_hover"
                android:orientation="vertical"
                android:paddingEnd="5dp"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/ll_previous"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"

                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="@dimen/card_corner_radius_5dp">

                    <ImageView
                        android:id="@+id/tv_cancel"
                        android:layout_width="@dimen/plan_direction_screen_view_height"
                        android:layout_height="@dimen/plan_direction_screen_view_height"
                        android:gravity="center"
                        android:src="@drawable/ic_cross_fill" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_next"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="@dimen/card_corner_radius_5dp">

                    <ImageView
                        android:id="@+id/tv_save"
                        android:layout_width="@dimen/plan_direction_screen_view_height"
                        android:layout_height="@dimen/plan_direction_screen_view_height"
                        android:gravity="center"
                        android:src="@drawable/ic_tick_fill" />
                </LinearLayout>


            </LinearLayout>

        </LinearLayout>


        <LinearLayout
            android:id="@+id/ll_parent_view"
            android:layout_width="@dimen/crop_image_height"
            android:layout_height="@dimen/crop_image_height"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:background="@drawable/linenew">

            <ImageView
                android:id="@+id/cropImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>
    </RelativeLayout>


</FrameLayout>
