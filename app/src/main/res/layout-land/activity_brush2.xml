<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_background_dark_translucent"
>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/brush"
        app:titleTextColor="@color/white_text_color" />


    <com.projectdocupro.mobile.utility.VScroll
        android:id="@+id/vScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@+id/toolbar"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="-3dp"
        android:background="@color/settings_background_dark_translucent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <com.projectdocupro.mobile.photoview.PhotoViewPainting
            android:id="@+id/photoEditorView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/toolbar"
            android:background="@color/color_black" />
        <!--  <com.test.projectdocu.utility.HScroll android:id="@+id/hScroll"
              android:layout_width="match_parent" android:layout_height="match_parent"
              android:background="@color/settings_background_dark_translucent"

              >
          </com.test.projectdocu.utility.HScroll>-->
    </com.projectdocupro.mobile.utility.VScroll>

    <TextView
        android:id="@+id/tv_edit"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="@dimen/size15"
        android:background="@drawable/rounded_blue_theme"
        android:gravity="center"
        android:padding="3dp"
        android:text="Edit"
        android:textColor="@color/white"
        android:textSize="@dimen/size16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"

        />

    <LinearLayout
        android:id="@+id/ll_icons"
        android:layout_width="wrap_content"
        android:layout_height="0dp"

        android:background="@color/settings_background_dark_translucent"
        android:orientation="vertical"
        android:paddingLeft="5dp"
        android:paddingTop="10dp"
        android:paddingRight="5dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ll_bottom_view"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <ImageView
            android:id="@+id/iv_black_color"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/black_circle"
            android:layout_margin="2dp"/>

        <ImageView
            android:id="@+id/iv_blue_color"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="record"
            android:src="@drawable/blue_circle"
            android:textColor="@color/white_text_color"
            android:layout_margin="2dp"/>

        <ImageView
            android:id="@+id/iv_green_color"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="Tag"
            android:src="@drawable/green_circle"
            android:textColor="@color/white_text_color"
            android:layout_margin="2dp"/>



        <ImageView
            android:id="@+id/iv_yellow_color"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="Plan"
            android:src="@drawable/yellow_cricle"
            android:textColor="@color/white_text_color"
            android:layout_margin="2dp"/>

        <ImageView
            android:id="@+id/iv_red_color"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"

            android:layout_weight="1"
            android:contentDescription="Comment"
            android:src="@drawable/red_circle"
            android:textColor="@color/white_text_color"
            android:layout_margin="2dp"/>


        <ImageView
            android:id="@+id/iv_brush_size_3"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:contentDescription="Save"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:src="@drawable/white_line_thick"
            android:textColor="@color/black_text_color"
            android:layout_margin="2dp"/>

        <ImageView
            android:id="@+id/iv_brush_size_2"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="Save"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:src="@drawable/white_line_medium"
            android:textColor="@color/black_text_color"
            android:layout_margin="2dp"/>

        <ImageView
            android:id="@+id/iv_brush_size_1"
            android:layout_width="@dimen/brush_image_height"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="Save"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:src="@drawable/white_line_thin"
            android:textColor="@color/black_text_color"
            android:layout_margin="2dp"/>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_bottom_view"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:background="@color/white"
        android:orientation="vertical"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <ImageButton
            android:id="@+id/brush_color"
            android:layout_width="45dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_tick_fill"
            android:textColor="@color/white_text_color"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/brush_settings"
            android:layout_width="45dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_cross_fill"
            android:text="@string/cancel"
            android:textColor="@color/white_text_color"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>