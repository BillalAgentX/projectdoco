<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_white"
    tools:context=".activities.BrushActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/brush"
        app:titleTextColor="@color/white_text_color" />

    <com.projectdocupro.mobile.brushViewFiles.PhotoEditorView
        android:id="@+id/photoEditorView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/color_black"
        app:layout_constraintBottom_toTopOf="@+id/ll_icons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar" />



    <LinearLayout
        android:id="@+id/ll_icons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/translucent_with_80_per"
        android:orientation="horizontal"
        android:paddingLeft="5dp"
        android:paddingTop="10dp"
        android:paddingRight="5dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/brush_settings">

        <ImageView
            android:id="@+id/iv_brush_size_1"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:paddingBottom="3dp"
            android:paddingTop="3dp"
            android:contentDescription="Save"
            android:src="@drawable/white_line_thin"
            android:textColor="@color/black_text_color" />

        <ImageView
            android:id="@+id/iv_brush_size_2"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:paddingBottom="3dp"
            android:paddingTop="3dp"
            android:contentDescription="Save"
            android:src="@drawable/white_line_medium"
            android:textColor="@color/black_text_color" />

        <ImageView
            android:id="@+id/iv_brush_size_3"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:paddingBottom="3dp"
            android:paddingTop="3dp"
            android:contentDescription="Save"
            android:src="@drawable/white_line_thick"
            android:textColor="@color/black_text_color" />

        <ImageView
            android:id="@+id/iv_red_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_marginStart="@dimen/card_corner_radius_5dp"
            android:layout_weight="1"
            android:contentDescription="Comment"
            android:src="@drawable/red_circle"
            android:textColor="@color/white_text_color" />


        <ImageView
            android:id="@+id/iv_yellow_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:contentDescription="Plan"
            android:src="@drawable/yellow_cricle"
            android:textColor="@color/white_text_color" />

        <ImageView
            android:id="@+id/iv_green_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:contentDescription="Tag"
            android:src="@drawable/green_circle"
            android:textColor="@color/white_text_color" />

        <ImageView
            android:id="@+id/iv_blue_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:contentDescription="record"
            android:src="@drawable/blue_circle"
            android:textColor="@color/white_text_color" />

        <ImageView
            android:id="@+id/iv_black_color"
            android:layout_width="0dp"
            android:layout_height="@dimen/brush_image_height"
            android:layout_weight="1"
            android:src="@drawable/black_circle"
            />
    </LinearLayout>


    <Button
        android:id="@+id/brush_settings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#bb000000"
        android:text="@string/cancel"
        android:textColor="@color/white_text_color"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/brush_color"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#bb000000"
        android:text="@string/save"
        android:textColor="@color/white_text_color"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />
</androidx.constraintlayout.widget.ConstraintLayout>