<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:id="@+id/card_parent"
        android:background="@drawable/dialog_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/project_icon_start_margin_parent"
            android:orientation="vertical"
            android:padding="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/project_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:textColor="@color/black_text_color"
                android:textSize="16sp"
                android:typeface="sans"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/plan_label"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="@dimen/size8"
                android:text="@string/place_label"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/project_name" />

            <TextView
                android:id="@+id/plan_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size8"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintEnd_toStartOf="@+id/iv_sync"
                app:layout_constraintStart_toEndOf="@id/plan_label"
                app:layout_constraintTop_toBottomOf="@+id/project_name" />

            <TextView
                android:id="@+id/company_label"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="@string/company_label"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/plan_label" />

            <TextView
                android:id="@+id/company_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_sync"
                app:layout_constraintStart_toEndOf="@id/company_label"
                app:layout_constraintTop_toBottomOf="@+id/plan_label" />

            <TextView
                android:id="@+id/photos_label"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="16dp"
                android:text="@string/photos_label"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/company_label" />

            <TextView
                android:id="@+id/number_photos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text=""
                android:scrollHorizontally="true"
                android:textColor="#4F4F4F"
                android:textSize="12sp"
                android:typeface="sans"
                app:layout_constraintRight_toLeftOf="@id/iv_project_loading"
                app:layout_constraintLeft_toRightOf="@+id/photos_label"
                app:layout_constraintTop_toBottomOf="@+id/company_name" />


            <ProgressBar
                android:id="@+id/iv_project_loading"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="35dp"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:src="@drawable/sync_yellow_bg"
                android:text="@string/open_label"
                android:visibility="invisible"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/company_name" />

            <ImageView
                android:id="@+id/iv_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/sync_green_bg"
                android:text="@string/open_label"
                android:paddingRight="0dp"
                android:paddingLeft="0dp"
                android:visibility="invisible"

                android:layout_marginBottom="@dimen/size10"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/number_photos"
                app:layout_constraintTop_toBottomOf="@+id/project_name"
                app:layout_constraintBottom_toTopOf="@+id/number_photos" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>


    <ImageView
        android:id="@+id/project_image1"
        android:layout_width="@dimen/project_photo_width_1"
        android:layout_height="@dimen/project_icon_height_1"
        android:layout_marginStart="@dimen/project_icon_start_margin_1"
        android:background="@drawable/border_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/project_image"
        android:layout_width="@dimen/project_photo_width"
        android:layout_height="@dimen/project_icon_height"
        android:layout_marginStart="@dimen/project_icon_start_margin"
        android:layout_marginTop="@dimen/project_icon_top_margin"
        android:background="@color/white"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ImageView
        android:id="@+id/favorite_icon"
        android:layout_width="@dimen/project_listing_star_width"
        android:layout_height="@dimen/project_listing_star_height"
        android:layout_margin="10dp"
        android:src="@drawable/ic_not_favorite"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>