<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/show_photo_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.add_direction.ProjectDocuMainActivity">

    <com.projectdocupro.mobile.fragments.add_direction.EnhancedWebView
        android:id="@+id/webview_plan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:longClickable="true" />

    <ImageButton
        android:id="@+id/crosshair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:clickable="true"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/crosshair" />

    <ImageView
        android:id="@+id/touch_helper_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/color_transparent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <ImageView
        android:id="@+id/arrow_touch_helper_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/arrow_transparent"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/button_capture_photo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="top|right"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:scaleType="fitCenter"
        android:src="@drawable/pd_button_camera_008"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/rotation_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="20dp"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/rotation_arrow_top"
        android:visibility="visible" />

    <ImageButton
        android:id="@+id/rotation_arrow_helper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center"
        android:layout_margin="35dp"
        android:background="@color/color_transparent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/rotation_arrow_helper"
        android:visibility="invisible" />

    <!--
          <LinearLayout
           android:id="@+id/preview_function_buttons"
           android:orientation="vertical"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:visibility="visible">

                <ImageView
                    android:id="@+id/menu_bar_plan_button_gps"
                    android:layout_width="57dp"
                    android:layout_height="57dp"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/pd_plan_gps_044" />

                <ImageView
                    android:id="@+id/menu_bar_plan_button_compass"
                    android:layout_width="57dp"
                    android:layout_height="57dp"
                    android:onClick="zoomOut"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/pd_plan_compass_043" />

           </LinearLayout>
    -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible"
        tools:visibility="visible">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000"></TextView>

        <TextView
            android:id="@+id/textView2"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000">

        </TextView>

        <TextView
            android:id="@+id/textView3"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000"></TextView>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="222dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:textColor="#ff0000">

        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/plan_sidesubmenu_buttons"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_gravity="bottom|right"
        android:orientation="horizontal"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/plan_submenu_buttons_expanded"
            android:layout_width="wrap_content"
            android:layout_height="81dp"
            android:layout_gravity="bottom|right"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/button_delete_location"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/button_arrow_rotate"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/button_plan"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_overview_028"
                android:text="norotate"
                android:visibility="visible" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/plan_submenu_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|right"
            android:orientation="vertical"
            android:visibility="gone">


            <ImageView
                android:id="@+id/button_cancel_and_back"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:text="config"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/button_save_and_back"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_save_085"
                android:text="Plan"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/button_config"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="8dp"
                android:src="@drawable/pd_plan_selector_039"
                android:visibility="visible" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/debugTextView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:text="Test"
            android:textColor="#ff0000"
            android:textSize="20dp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/iv_temp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/yellow"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:src="@drawable/floor_1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/ll_icons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="@dimen/plan_detail_top_margin"
        android:background="@color/gray_lighter_light_hover"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="visible">


        <ImageView
            android:id="@+id/iv_satellite"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:contentDescription="Plan"
            android:src="@drawable/satellite_icon"
            android:textColor="@color/white_text_color"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_compass"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:contentDescription="Tag"
            android:src="@drawable/edit_plan_icon"
            android:textColor="@color/white_text_color" />

        <ImageView
            android:id="@+id/iv_plan"
            android:layout_width="0dp"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:contentDescription="record"
            android:src="@drawable/plans_black"
            android:textColor="@color/white_text_color" />

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:contentDescription="brush"
            android:src="@drawable/delete_icon_direction_screen"
            android:textColor="@color/white_text_color" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_bottom_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/light_gry_filter_bg"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#b0b0b0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/ll_previous"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_cancel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/cancel"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/size14" />
            </LinearLayout>

            <View
                android:layout_width="1px"
                android:layout_height="match_parent"
                android:background="#b0b0b0" />

            <LinearLayout
                android:id="@+id/ll_next"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:gravity="center"

                >

                <TextView
                    android:id="@+id/tv_save"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/save"
                    android:textColor="@color/black_text_color"
                    android:textSize="@dimen/size14" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
