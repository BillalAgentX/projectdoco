<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="10dp"
    android:paddingTop="15dp"
    android:paddingRight="10dp"
    android:paddingBottom="15dp">


    <ImageView
        android:id="@+id/iv_status"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:visibility="gone"
        android:layout_alignParentLeft="true"
        android:src="@drawable/error_indicator" />

    <ImageView
        android:id="@+id/clock_word"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:visibility="visible"
        android:src="@drawable/ic_clock_grey"/>

    <ImageView
        android:id="@+id/selected_word"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="10dp"
        android:visibility="invisible"

        android:background="@drawable/ic_unselected_word"/>

    <TextView
        android:id="@+id/sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="38dp"
        android:layout_marginEnd="10dp"
        android:textColor="@color/black_text_color"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_alignParentLeft="true"
        android:scrollHorizontally="true"
        android:padding="5dp"/>

    <EditText
        android:id="@+id/et_search_number"
        android:layout_width="140dp"
        android:layout_height="35dp"
        android:layout_marginStart="5dp"
        android:paddingLeft="@dimen/size8"
        android:paddingRight="@dimen/size8"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:layout_toLeftOf="@id/favorite_word_icon"
        android:background="@drawable/et_rounded_crnor_gry_background" />

    <ImageView
        android:id="@+id/favorite_word_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_gravity="right"
        android:layout_alignParentRight="true"
        android:src="@drawable/ic_not_favorite"/>





</RelativeLayout>