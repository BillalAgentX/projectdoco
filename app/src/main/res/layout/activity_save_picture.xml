<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cameraViewParent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SavePictureActivity">

    <!-- START OF rl_parent_save_picture -->

    <RelativeLayout
        android:id="@+id/rl_parent_save_picture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <RelativeLayout
            android:id="@+id/rl_photo_preview_section"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/ll_bottom_camera_view"
            android:background="@color/black">

        <!--    <include layout="@layout/saved_picture_img_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                ></include>-->

            <com.projectdocupro.mobile.photoview.ZoomImageView
                android:id="@+id/captured_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recent_words_rv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:layout_marginLeft="60dp"
                android:layout_marginTop="60dp"
                android:layout_marginRight="60dp"
                android:layout_marginBottom="80dp"
                android:paddingTop="100dp"
                android:rotation="0" />


            <ImageView
                android:id="@+id/toolbar"
                android:layout_width="40dp"
                android:layout_height="35dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_marginLeft="@dimen/size12"
                android:layout_marginTop="@dimen/size8"
                android:src="@drawable/ic_back"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/toolbar1"
                android:layout_width="40dp"
                android:layout_height="35dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_marginTop="@dimen/size12"
                android:layout_marginRight="@dimen/size8"
                android:rotation="90"
                android:src="@drawable/ic_back"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_delete"
                android:layout_width="40dp"
                android:layout_height="35dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_marginTop="@dimen/size12"
                android:layout_marginRight="@dimen/size8"
                android:rotation="0"
                android:src="@drawable/delete_icon"
                android:visibility="gone"
                tools:visibility="visible" />


        </RelativeLayout>

        <FrameLayout
            android:id="@+id/fl_camera_area"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/ll_bottom_camera_view"
            android:visibility="visible" />

        <ListView
            android:id="@+id/simpleListView"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_above="@+id/ll_icons"
            android:layout_centerHorizontal="true"
            android:layout_marginRight="@dimen/size8"
            android:layout_marginBottom="10dp"
            android:background="@drawable/btn_rounded_crnor_transluent_background"
            android:divider="@color/translucent_dark"
            android:dividerHeight="1dp"
            android:rotation="0"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_icons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/ll_bottom_camera_view"
            android:background="@color/translucent_with_80_per"
            android:orientation="horizontal"
            android:paddingBottom="@dimen/size12"
            android:rotation="0"

            android:visibility="gone">


            <RelativeLayout
                android:id="@+id/rl_word"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/word"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_save"
                    android:textColor="@color/black_text_color" />

                <ImageView
                    android:id="@+id/word_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/rl_comment"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/comment"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_comment"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/comment_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/rl_plan"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/plan"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_plans"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/plan_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_defects"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/defects"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_menu_flaws"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/defects_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_brush"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/brush"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_brush"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/brush_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_record"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="0">

                <ImageView
                    android:id="@+id/record"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_record"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/record_done"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


        </LinearLayout>

        <FrameLayout
            android:id="@+id/ll_bottom_camera_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/black">

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/size12"
                android:gravity="center"
                android:text="@string/cancel"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:typeface="sans" />

            <ImageView
                android:id="@+id/iv_camera"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:padding="@dimen/size12"
                android:rotation="0"
                android:src="@drawable/capture" />

            <ImageView
                android:id="@+id/iv_flash"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                android:padding="18dp"
                android:rotation="0"
                android:src="@drawable/flash_off"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_delete_rotated"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                android:padding="18dp"
                android:rotation="90"
                android:src="@drawable/delete_icon"
                android:visibility="gone" />


        </FrameLayout>

        <FrameLayout
            android:id="@+id/ll_bottom_camera_view_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="@color/black"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_delete_3"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/size14"
                android:layout_marginTop="@dimen/size12"
                android:padding="18dp"
                android:rotation="270"
                android:src="@drawable/delete_icon"
                android:visibility="visible" />


            <TextView
                android:id="@+id/tv_cancel_2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/size12"
                android:gravity="center"
                android:text="@string/cancel"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:typeface="sans"
                android:visibility="gone"/>

            <ImageView
                android:id="@+id/iv_camera_2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:padding="@dimen/size12"
                android:rotation="270"
                android:src="@drawable/capture" />

            <ImageView
                android:id="@+id/iv_flash_2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                android:padding="18dp"
                android:rotation="0"
                android:src="@drawable/flash_off"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_delete_rotated_2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                android:padding="18dp"
                android:rotation="90"
                android:src="@drawable/delete_icon"
                android:visibility="gone" />


        </FrameLayout>

        <LinearLayout
            android:id="@+id/ll_icons_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/ll_bottom_camera_view_2"
            android:background="@color/translucent_with_80_per"
            android:orientation="horizontal"
            android:paddingBottom="@dimen/size12"
            android:rotation="0"
            android:visibility="gone">


            <RelativeLayout
                android:id="@+id/rl_word_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/word_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_save"
                    android:textColor="@color/black_text_color" />

                <ImageView
                    android:id="@+id/word_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/rl_comment_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/comment_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_comment"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/comment_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/rl_plan_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/plan_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_plans"
                    android:textColor="@color/white_text_color"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/plan_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_defects_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/defects_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_menu_flaws"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/defects_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_brush_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/brush_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_brush"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/brush_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rl_record_2"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_weight="1"
                android:rotation="270">

                <ImageView
                    android:id="@+id/record_2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Plan"
                    android:src="@drawable/ic_record"
                    android:textColor="@color/white_text_color" />

                <ImageView
                    android:id="@+id/record_done_2"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/done_margin_start"
                    android:layout_marginTop="@dimen/done_margin_top"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_done"
                    android:visibility="gone" />
            </RelativeLayout>


        </LinearLayout>

        <RelativeLayout
            android:id="@+id/rlRotatedBackDeleted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:padding="20dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/toolbar_3"
                android:layout_width="40dp"
                android:layout_height="35dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_marginLeft="@dimen/size12"
                android:layout_marginTop="@dimen/size8"
                android:src="@drawable/ic_back"
                android:visibility="visible"
                android:rotation="270"
                android:layout_alignParentStart="true"/>

        </RelativeLayout>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/pb_loader"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent_black_50"
        android:visibility="gone">

        <ProgressBar

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/colorPrimary"

            />
    </RelativeLayout>

    <!-- END OF pb_loader -->
    <TextView
        android:id="@+id/compass_status"
        android:padding="38dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:textSize="24dp"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:text="compass angle:"
        android:textColor="#ff0000"></TextView>
</RelativeLayout>