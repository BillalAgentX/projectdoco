<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/photo_filter_header_left_padding_edittext"
    android:paddingTop="12dp"
    android:paddingRight="@dimen/photo_filter_header_left_padding"
    android:paddingBottom="12dp">


    <ImageView
        android:id="@+id/iv_status"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:visibility="gone"
        android:layout_alignParentLeft="true"
        android:src="@drawable/error_indicator" />

    <TextView
        android:id="@+id/sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="0dp"
        android:layout_marginLeft="0dp"
        android:layout_marginEnd="10dp"
        android:layout_toLeftOf="@id/et_search"
        android:layout_alignParentLeft="true"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_centerVertical="true"
        android:scrollHorizontally="true"
        android:text="@string/project"
        android:textColor="@color/black_text_color"
        android:textSize="15sp"
        android:typeface="sans"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_search"
        android:layout_width="@dimen/photo_filter_search_bar_width"
        android:layout_height="@dimen/photo_filter_search_bar_height"
        android:layout_alignParentRight="true"
        android:layout_marginStart="5dp"
        android:paddingLeft="@dimen/size8"
        android:paddingRight="@dimen/size8"
        android:singleLine="true"
        android:background="@drawable/et_rounded_crnor_gry_background" >
    </EditText>

</RelativeLayout>