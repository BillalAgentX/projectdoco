<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white_text_color"
    android:paddingLeft="@dimen/photo_filter_header_left_padding"
    android:paddingTop="12dp"
    android:paddingRight="@dimen/photo_filter_header_left_padding"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_toLeftOf="@id/swh"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"        android:text="Title"
        android:textColor="@color/black_text_color"
        android:textSize="15sp"
        android:typeface="sans"
        android:textStyle="bold" />


    <Switch
        android:id="@+id/swh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        />
</RelativeLayout>