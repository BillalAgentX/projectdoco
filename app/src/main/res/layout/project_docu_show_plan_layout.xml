    <LinearLayout
       android:orientation="vertical"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:visibility="visible">
      
      <TextView
          android:id="@+id/textView"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >
      </TextView>

      <TextView
          android:id="@+id/textView2"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >

	  </TextView>
	  <TextView
          android:id="@+id/textView3"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >
	  </TextView>
      <TextView
          android:id="@+id/textView4"
          android:layout_width="222dp"
          android:layout_height="wrap_content"
          android:ems="10"
          android:textColor="#ff0000" >

	  </TextView>
	  
      </LinearLayout>
      
      <LinearLayout
          android:id="@+id/plan_sidesubmenu_buttons"
          android:layout_width="wrap_content"
          android:layout_height="fill_parent"
          android:layout_gravity="bottom|right"
          android:orientation="horizontal"
          android:visibility="visible" >

		  <LinearLayout
			  android:id="@+id/plan_submenu_buttons_expanded"
			  android:layout_width="wrap_content"
			  android:layout_height="81dp"
			  android:layout_gravity="bottom|right"
			  android:orientation="horizontal"
			  android:visibility="invisible">

			  <ImageView
				  android:id="@+id/button_delete_location"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_selector_039"
				  android:visibility="visible" />

			  <ImageView
				  android:id="@+id/button_arrow_rotate"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_selector_039"
				  android:visibility="visible" />

			  <ImageView
				  android:id="@+id/button_plan"
				  android:layout_width="50dp"
				  android:layout_height="50dp"
				  android:layout_margin="8dp"
				  android:src="@drawable/pd_plan_overview_028"
				  android:text="norotate"
				  android:visibility="visible" />
		  </LinearLayout>
                     

      <LinearLayout
          android:id="@+id/plan_submenu_buttons"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom|right"
          android:orientation="vertical"
          android:visibility="visible" >

		
		   <ImageView
		       android:id="@+id/button_cancel_and_back"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
			   android:src="@drawable/pd_plan_selector_039"
		       android:visibility="visible"
		       android:text="config" />

		   <ImageView
		       android:id="@+id/button_save_and_back"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
		       android:src="@drawable/pd_plan_save_085"
		       android:visibility="visible"
		       android:text="Plan" />
		   		
		   <ImageView
		       android:id="@+id/button_config"
		       android:layout_width="50dp"
		       android:layout_height="50dp"
		       android:layout_margin="8dp"
			   android:src="@drawable/pd_plan_selector_039"
		       android:visibility="visible"/>
      	  
	    </LinearLayout>
    </LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:visibility="gone"
		>

		<TextView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:text="Test"
			android:layout_margin="5dp"
			android:textColor="#ff0000"
			android:textSize="20dp"
			android:id="@+id/debugTextView"
		/>

	</LinearLayout>
	<ImageView
		android:id="@+id/iv_temp"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:focusable="false"
		android:visibility="gone"

		android:background="@color/yellow"
		android:src="@drawable/floor_1"
		android:focusableInTouchMode="false" />
     
</FrameLayout>
