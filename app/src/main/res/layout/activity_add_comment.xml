<?xml version="1.0" encoding="utf-8"?><androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    xmlns:tools="http://schemas.android.com/tools"    android:layout_width="match_parent"    android:layout_height="match_parent"    android:background="#ececec"    tools:context=".activities.AddCommentActivity">    <androidx.appcompat.widget.Toolbar        android:id="@+id/toolbar"        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:background="@color/colorPrimary"        app:title="@string/add_description"        app:navigationIcon="@drawable/ic_back"        app:titleTextColor="@color/white_text_color"        app:layout_constraintTop_toTopOf="parent"/>    <EditText        android:id="@+id/comments"        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:layout_margin="10dp"        android:padding="10dp"        android:minLines="10"        android:hint="@string/comments"        android:textSize="12sp"        android:gravity="start"        android:background="@color/white_text_color"        android:textColor="@color/black_text_color"        app:layout_constraintTop_toBottomOf="@+id/toolbar" />    <LinearLayout        android:id="@+id/ll_bottom_tabs"        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:background="@color/light_gry_filter_bg"        android:layout_gravity="bottom"        app:layout_constraintBottom_toBottomOf="parent"        android:orientation="vertical">        <View            android:layout_width="match_parent"            android:layout_height="1px"            android:background="#b0b0b0" />        <LinearLayout            android:layout_width="match_parent"            android:layout_height="wrap_content"            android:orientation="horizontal"            >            <LinearLayout                android:layout_width="match_parent"                android:layout_height="55dp"                android:layout_weight="1"                android:id="@+id/ll_previous"                android:gravity="center">                <TextView                    android:id="@+id/tv_cancel"                    android:layout_width="wrap_content"                    android:layout_height="wrap_content"                    android:layout_weight="1"                    android:textSize="@dimen/size14"                    android:gravity="center"                    android:textColor="@color/black_text_color"                    android:text="@string/cancel"                    />            </LinearLayout>            <View                android:layout_width="1px"                android:layout_height="match_parent"                android:background="#b0b0b0" />            <LinearLayout                android:layout_width="match_parent"                android:layout_height="55dp"                android:layout_weight="1"                android:gravity="center"                android:id="@+id/ll_next"                >                <TextView                    android:id="@+id/tv_save"                    android:layout_width="wrap_content"                    android:layout_height="wrap_content"                    android:layout_weight="1"                    android:textColor="@color/black_text_color"                    android:gravity="center"                    android:textSize="@dimen/size14"                    android:text="@string/save"                    />            </LinearLayout>        </LinearLayout>    </LinearLayout></androidx.constraintlayout.widget.ConstraintLayout>