<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gray_lighter"

        >

        <LinearLayout
            android:id="@+id/customDialog_titlebar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="@dimen/size14"
            android:orientation="vertical">


            <TextView
                android:id="@+id/customDialog_titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:maxLines="1"
                android:singleLine="true"
                android:text="@string/heading_photo_keyword"
                android:textColor="@color/black"
                android:gravity="center"
                android:textSize="18dp"
                android:textStyle="bold"
                android:typeface="serif" />
            <TextView
                android:visibility="gone"
                android:id="@+id/customDialog_content_Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:maxLines="1"

                android:layout_marginTop="@dimen/card_corner_radius_5dp"
                android:singleLine="true"
                android:text="EasyTickets"
                android:textColor="@color/black"
                android:gravity="center"
                android:textSize="15dp"
                android:textStyle="normal"
                android:typeface="monospace" />
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <EditText
                        android:id="@+id/et_search_number"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginStart="@dimen/size30"
                        android:layout_marginEnd="@dimen/size30"
                        android:layout_marginTop="@dimen/size20"
                        android:layout_marginBottom="@dimen/size20"
                        android:paddingLeft="@dimen/size8"
                        android:paddingRight="@dimen/size8"
                        android:singleLine="true"
                        android:background="@drawable/btn_rounded_crnor_white_background"
                        android:textColor="@color/black"
                        android:layout_below="@id/sub_title"
                        android:imeOptions="actionDone"
                        android:layout_toLeftOf="@id/favorite_word_icon"
                        />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:background="#b0b0b0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:layout_weight="1"
                            android:id="@+id/ll_previous"
                            android:clickable="true"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_cancel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="@dimen/size14"
                                android:gravity="center"
                                android:textColor="@color/blue_brush"
                                android:text="@string/cancel"
                                />
                        </LinearLayout>
                        <View
                            android:layout_width="1px"
                            android:layout_height="match_parent"
                            android:background="#b0b0b0" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:id="@+id/ll_next"

                            >

                            <TextView
                                android:id="@+id/tv_save"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/blue_brush"
                                android:gravity="center"
                                android:textSize="@dimen/size14"
                                android:text="@string/save"
                                />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>