<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/light_gry_filter_child_bg"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="30dp"
    android:paddingTop="15dp"
    android:paddingRight="30dp"
    android:paddingBottom="15dp">


    <ImageView
        android:id="@+id/iv_status"
        android:layout_width="@dimen/photo_filter_icon_width"
        android:layout_height="@dimen/photo_filter_icon_height"
        android:layout_alignParentLeft="true"
        android:src="@drawable/error_indicator" />

    <TextView
        android:id="@+id/sub_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginLeft="10dp"
        android:layout_marginEnd="10dp"
        android:layout_toLeftOf="@id/iv_selected_word"
        android:layout_toRightOf="@id/iv_status"
        android:ellipsize="end"
        android:maxLines="1"
        android:padding="5dp"
        android:scrollHorizontally="true"
        android:text="@string/project"
        android:textColor="@color/black_text_color"
        android:textSize="14sp"
        android:typeface="sans"
        android:textStyle="normal"/>

    <ImageView
        android:id="@+id/iv_selected_word"
        android:layout_width="@dimen/photo_filter_icon_width"
        android:layout_height="@dimen/photo_filter_icon_height"
        android:layout_alignParentRight="true"
        android:layout_marginStart="10dp"
        android:background="@drawable/ic_unselected_filter" />

</RelativeLayout>