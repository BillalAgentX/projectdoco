<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activities.SplashActivity">

    <ImageView
        android:id="@+id/image_logo"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/size50"
        android:src="@drawable/ic_docu_logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/image_logo"
        android:layout_marginStart="@dimen/size20"
        android:layout_marginEnd="@dimen/size20"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="Nutzungsbedingungen"
            android:textColor="@color/black_text_color"
            android:textSize="@dimen/sp24"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_privacy_policy"
            android:layout_width="match_parent"
            android:gravity="center"
            android:textSize="@dimen/sp18"
            android:textColor="@color/black"
            android:autoLink="web"
            android:layout_marginTop="@dimen/size20"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_accept"
            android:layout_width="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/sp18"
            android:textColor="@color/white"
            android:text="Akzeptieren"
            android:paddingRight="@dimen/size20"
            android:paddingLeft="@dimen/size20"
            android:paddingTop="@dimen/size10"
            android:paddingBottom="@dimen/size10"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/privacy_policy_accept_btn_bg"
            android:layout_marginTop="@dimen/size20"
            android:layout_height="wrap_content" />


    </LinearLayout>
</RelativeLayout>