<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="@dimen/photo_filter_header_left_padding"
    android:paddingTop="12dp"
    android:paddingRight="@dimen/photo_filter_header_left_padding"
    android:paddingBottom="12dp"
    android:background="@color/white_text_color"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_toLeftOf="@id/iv_arrow"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Title"
        android:textSize="17sp"
        android:typeface="sans"
        android:textColor="@color/black_text_color"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/iv_arrow"
        android:layout_width="@dimen/photo_filter_icon_width"
        android:layout_height="@dimen/photo_filter_icon_height"
       android:layout_alignParentRight="true"
        android:visibility="visible"
        android:rotation="0"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_down_arrow" />
</RelativeLayout>