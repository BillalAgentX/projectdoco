<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/activity_vertical_margin">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/heading_status"
                    android:textColor="@color/black"
                    android:typeface="sans"
                    android:textSize="16sp" />


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="0.3"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">
                <ImageView
                    android:id="@+id/iv_status_red"
                    android:layout_width="@dimen/photo_filter_icon_height"
                    android:layout_height="@dimen/photo_filter_icon_height"
                    android:layout_margin="10dp"
                    android:background="@drawable/red_circle_background" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentLeft="true"
                        android:text="@string/open_status"
                        android:textColor="@color/black"
                        android:typeface="sans"
                        android:textSize="12sp"/>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="0.3"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_status_orange"
                        android:layout_width="@dimen/photo_filter_icon_height"
                        android:layout_height="@dimen/photo_filter_icon_height"
                        android:layout_margin="@dimen/size10"
                        android:background="@drawable/orange_circle_background" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentLeft="true"
                        android:text="@string/progress_status"
                        android:textColor="@color/black"
                        android:typeface="sans"
                        android:textSize="12sp"/>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="0.3"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_status_green"
                        android:layout_width="@dimen/photo_filter_icon_height"
                        android:layout_height="@dimen/photo_filter_icon_height"
                        android:layout_margin="@dimen/size10"
                        android:background="@drawable/green_circle_background" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentLeft="true"
                        android:text="@string/close_status"
                        android:textColor="@color/black"
                        android:typeface="sans"
                        android:textSize="12sp"/>
                </LinearLayout>




            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/card_corner_radius_5dp"
                android:background="#b0b0b0" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="@dimen/size10"
                android:text="@string/defect_screen_flaw_name"
                android:textColor="@color/black"
                android:typeface="sans"
                android:textSize="16sp"/>


            <EditText
                android:id="@+id/et_flaw_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_corner_radius_5dp"
                android:layout_marginBottom="@dimen/size10"
                android:background="@null"
                android:hint="@string/defect_screen_flaw_name"
                android:inputType="text"
                android:maxLines="1"
                android:text=""
                android:typeface="sans"
                android:textColor="#828282"
                android:textSize="19sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size10"
                android:text="@string/heading_art"
                android:textColor="@color/black"
                android:typeface="sans"
                android:textSize="16sp"/>


            <RelativeLayout
                android:id="@+id/rl_art_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/project_icon_top_margin"
                android:paddingBottom="@dimen/card_corner_radius_5dp"

                >

                <TextView
                    android:id="@+id/art_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginTop="@dimen/card_corner_radius_5dp"
                    android:layout_marginBottom="@dimen/size10"
                    android:text=""
                    android:textColor="#828282"
                    android:textSize="19sp" />

                <ImageView
                    android:id="@+id/iv_arrow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="5dp"
                    android:layout_toLeftOf="@+id/art_text"
                    android:rotation="0"
                    android:src="@drawable/ic_down_arrow"
                    android:visibility="visible" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size10"
                android:text="@string/heading_gewerk"
                android:textColor="@color/black"
                android:typeface="sans"
                android:textSize="16sp" />

            <RelativeLayout
                android:id="@+id/rl_trade_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/project_icon_top_margin"
                android:paddingBottom="@dimen/card_corner_radius_5dp">

                <TextView
                    android:id="@+id/company_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginTop="@dimen/card_corner_radius_5dp"
                    android:layout_marginBottom="@dimen/size10"
                    android:layout_toLeftOf="@+id/iv_arrow1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text=""
                    android:textColor="#828282"
                    android:textSize="19sp" />

                <ImageView
                    android:id="@+id/iv_arrow1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="5dp"
                    android:rotation="0"
                    android:src="@drawable/ic_down_arrow"
                    android:visibility="visible" />
            </RelativeLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size10"
                android:text="@string/heading_responsible"
                android:textColor="@color/black"
                android:typeface="sans"
                android:textSize="16sp" />

            <RelativeLayout
                android:id="@+id/rl_users_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/project_icon_top_margin"
                android:paddingBottom="@dimen/card_corner_radius_5dp">

                <TextView
                    android:id="@+id/name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginTop="@dimen/card_corner_radius_5dp"
                    android:layout_marginBottom="@dimen/size10"
                    android:layout_toLeftOf="@id/iv_arrow"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text=""
                    android:textColor="#828282"
                    android:textSize="19sp" />

                <ImageView
                    android:id="@+id/iv_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="5dp"
                    android:rotation="0"
                    android:src="@drawable/ic_down_arrow"
                    android:visibility="visible" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/light_gray_bg"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/created_date"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/first_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="10dp"
                        android:text=""
                        android:textColor="@color/black_text_color"
                        android:textSize="18sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#b0b0b0" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_priority_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"

                    >


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/size10"
                        android:layout_weight="3"
                        android:orientation="horizontal"

                        >


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/defect_screen_priorities"
                            android:textColor="@color/black"
                            android:typeface="sans"
                            android:textSize="16sp" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:background="@drawable/add_defect_white_background_gray_border"
                            android:minHeight="40dp"
                            android:orientation="horizontal"
                            android:weightSum="4"

                            >

                            <TextView
                                android:id="@+id/tv_date_1"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/tv_date_2"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/tv_date_3"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/tv_date_4"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:gravity="center"
                                android:text="4"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp" />


                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="5dp"
                        android:layout_weight="3"
                        android:orientation="horizontal"

                        >


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/defect_screen_priorities"
                            android:textSize="20sp"
                            android:visibility="invisible" />


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="horizontal"
                            android:weightSum="4"

                            >

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/defect_screen_highest_priorities"
                                android:textColor="@color/gray_bg"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="T2"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp"
                                android:visibility="invisible" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="T3"
                                android:textColor="@color/gray_bg"
                                android:textSize="18sp"
                                android:visibility="invisible" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/defect_screen_lowest_priorities"
                                android:textColor="@color/gray_bg"
                                android:textSize="12sp" />


                        </LinearLayout>
                    </LinearLayout>


                </LinearLayout>


                <ImageView
                    android:id="@+id/calender_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/activity_vertical_margin"
                    android:src="@drawable/ic_calendar_icon"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/dv"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/size8"
                    android:weightSum="3">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/size10"
                        android:layout_toLeftOf="@id/iv_selected_word"
                        android:layout_toRightOf="@id/iv_status"
                        android:layout_weight="1.5"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingLeft="5dp"
                        android:text="@string/defect_screen_days"
                        android:textColor="@color/black"
                        android:typeface="sans"
                        android:textSize="16sp"/>


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/iv_selected_word_start_date"
                        android:layout_toRightOf="@id/iv_status"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="left"
                        android:maxLines="1"
                        android:text="@string/heading_deadline"
                        android:textColor="@color/black"
                        android:typeface="sans"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="25dp"
                        android:layout_alignParentRight="true"
                        android:layout_weight="0.5"
                        android:src="@drawable/calendar_icon"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_start_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/dv"
                    android:orientation="horizontal"
                    android:paddingBottom="@dimen/size8"
                    android:weightSum="3"

                    >

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:layout_toLeftOf="@id/iv_selected_word"
                        android:layout_toRightOf="@id/iv_status"
                        android:layout_weight="1.5">
                        <Spinner
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:id="@+id/sp_days"
                            android:background="@null"
                            android:visibility="invisible"
                            />
                    <TextView
                        android:id="@+id/et_days"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:ellipsize="end"
                        android:hint="@string/defect_screen_days"
                        android:inputType="number"
                        android:maxLength="4"
                        android:padding="5dp"
                        android:typeface="sans"
                        android:textColor="#828282"
                        android:textSize="19sp" />
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginRight="5dp"
                            android:layout_toLeftOf="@+id/et_days"
                            android:rotation="0"
                            android:src="@drawable/ic_down_arrow"
                            android:visibility="visible" />

                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tv_end_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/iv_selected_word_start_date"
                        android:layout_toRightOf="@id/iv_status"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:ellipsize="end"
                        android:gravity="left"
                        android:maxLines="1"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="2019/02/09"
                        android:typeface="sans"
                        android:textColor="#828282"
                        android:textSize="19sp" />

                    <ImageView
                        android:id="@+id/iv_end_date"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_filter_icon_height"
                        android:layout_alignParentRight="true"
                        android:layout_weight="0.5"
                        android:gravity="left"
                        android:src="@drawable/calendar_icon" />
                </LinearLayout>


            </LinearLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#b0b0b0" />


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginTop="@dimen/size10"
                    android:text="@string/notes"
                    android:textColor="@color/black"
                    android:typeface="sans"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/iv_close"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_margin="10dp"
                    android:src="@drawable/cross" />
            </RelativeLayout>


            <EditText
                android:id="@+id/description_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/add_defect_white_background_gray_border"
                android:hint="@string/add_description"
                android:gravity="left|top"
                android:padding="@dimen/size8"
                android:inputType="textMultiLine"
                android:maxLines="15"
                android:minHeight="150dp"
                android:text=""
                android:textColor="#828282"
                android:textSize="18sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>