<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/light_gry_filter_child_bg"
    android:orientation="vertical"
    android:gravity="center">

    <RelativeLayout
        android:id="@+id/rl_normal_noticedate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="30dp"
        android:paddingTop="15dp"
        android:visibility="gone"
        android:paddingRight="30dp"
        android:paddingBottom="15dp">

        <TextView
            android:id="@+id/sub_title_noticedate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word_noticedate"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="5dp"
            android:scrollHorizontally="true"
            android:text="@string/notice_date"
            android:textColor="@color/black_text_color"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iv_selected_word_noticedate"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_marginStart="10dp"
            android:background="@drawable/ic_unselected_filter" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rl_normal"
        android:visibility="gone"
        android:background="@color/light_gry_filter_bg" />
    <RelativeLayout
        android:id="@+id/rl_normal_notifiedate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="30dp"
        android:paddingTop="15dp"
        android:paddingRight="30dp"
        android:visibility="gone"

        android:paddingBottom="15dp">

        <TextView
            android:id="@+id/sub_title_notifiedate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word_notifiedate"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="5dp"
            android:scrollHorizontally="true"
            android:text="@string/notify_date"
            android:textColor="@color/black_text_color"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iv_selected_word_notifiedate"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_marginStart="10dp"
            android:background="@drawable/ic_unselected_filter" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rl_normal"
        android:visibility="gone"

        android:background="@color/light_gry_filter_bg" />
    <RelativeLayout
        android:id="@+id/rl_normal_donedate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="30dp"
        android:paddingTop="15dp"
        android:paddingRight="30dp"
        android:visibility="gone"

        android:paddingBottom="15dp">

        <TextView
            android:id="@+id/sub_title_donedate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word_donedate"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="5dp"
            android:scrollHorizontally="true"
            android:text="@string/done_date"
            android:textColor="@color/black_text_color"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iv_selected_word_donedate"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_marginStart="10dp"
            android:background="@drawable/ic_unselected_filter" />

    </RelativeLayout>

    <View
        android:id="@+id/dv"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rl_normal"
        android:visibility="gone"
        android:background="@color/light_gry_filter_bg" />
        <LinearLayout
            android:id="@+id/ll_start_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="30dp"
            android:paddingTop="15dp"
            android:paddingRight="30dp"
            android:paddingBottom="15dp"
            android:layout_below="@+id/dv"

            >



        <TextView
            android:id="@+id/sub_title_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word"
            android:layout_toRightOf="@id/iv_status"
            android:layout_weight="0.6"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="5dp"
            android:text="@string/start_date"
            android:textColor="@color/black_text_color"
            android:textSize="14sp" />


        <TextView
            android:id="@+id/tv_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word_start_date"
            android:layout_toRightOf="@id/iv_status"
            android:layout_weight="1.7"
            android:ellipsize="end"
            android:gravity="right"
            android:maxLines="1"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="@string/project"
            android:textColor="@color/black_text_color"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/iv_selected_word_start_date"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:layout_weight="0.5"
            android:src="@drawable/calendar_icon" />
        </LinearLayout>
    <View
        android:id="@+id/dv1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rl_normal"
        android:visibility="visible"
        android:layout_marginLeft="45dp"
        android:layout_marginRight="45dp"
        android:background="@color/light_gry_filter_bg" />
    <LinearLayout
        android:id="@+id/ll_end_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:paddingBottom="15dp"
        android:paddingTop="15dp"
        android:layout_below="@+id/dv"

        >



        <TextView
            android:id="@+id/sub_title_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word"
            android:layout_toRightOf="@id/iv_status"
            android:layout_weight="0.6"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="5dp"
            android:text="@string/end_date"
            android:textColor="@color/black_text_color"
            android:textSize="14sp" />


        <TextView
            android:id="@+id/tv_end_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_toLeftOf="@id/iv_selected_word_date"
            android:layout_toRightOf="@id/iv_status"
            android:layout_weight="1.7"
            android:ellipsize="end"
            android:gravity="right"
            android:maxLines="1"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="@string/project"
            android:textColor="@color/black_text_color"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/iv_selected_end_date"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:layout_weight="0.5"
            android:src="@drawable/calendar_icon" />
    </LinearLayout>
</LinearLayout>